//@version=6
// 
// ─── Nexus Flow ─────────────────────────────────────────────────────────
//  Multi-Dimensional Trend & Momentum Suite
//  ────────────────────────────────────────────────────────────────────────
//  Combines adaptive trend detection, volatility-adjusted momentum, 
//  multi-timeframe context, and a clean information dashboard into 
//  one lightweight, professional-grade indicator.
// 
//  Features:
//    • Composite Trend Engine (EMA + ALMA + Supertrend consensus)
//    • Adaptive RSI with volatility-bounded lookback
//    • ATR Volatility Bands with regime coloring
//    • High-quality signal markers for entries/exits
//    • MTF confirmation (higher timeframe trend filter)
//    • Compact info table with live metrics
//    • One-click alerts via TradingView alert system
// ─────────────────────────────────────────────────────────────────────────
indicator(
     title      = "Nexus Flow",
     shorttitle = "Nexus Flow",
     overlay    = true,
     format     = format.price,
     precision  = 2
     )

// ─── Inputs ────────────────────────────────────────────────────────────
// Trend inputs
trendSrc        = input.source(close, "Trend Source")
trendFastLen    = input.int(9,    "Fast EMA",       minval=2)
trendSlowLen    = input.int(21,   "Slow EMA",       minval=5)
trendAlmaLen    = input.int(14,   "ALMA Length",    minval=2)
almaOffset      = input.float(0.85, "ALMA Offset",  minval=0.0, maxval=1.0, step=0.05)
almaSigma       = input.float(6.0,  "ALMA Sigma",   minval=0.5, maxval=15.0, step=0.5)
stFactor        = input.float(3.0,  "Supertrend Factor", minval=1.0, step=0.1)
stPeriod        = input.int(10,     "Supertrend ATR Period", minval=2)

// Momentum inputs
rsiLen          = input.int(14,  "RSI Length", minval=2)
rsiOB           = input.int(70,  "RSI Overbought", minval=50, maxval=95)
rsiOS           = input.int(30,  "RSI Oversold", minval=5,   maxval=50)
useAdaptive     = input.bool(true, "Adaptive RSI Lookback")

// Volatility inputs
atrLen          = input.int(14,  "ATR Length",    minval=2)
bandMultiplier  = input.float(2.0, "Band Multiplier", minval=0.5, maxval=5.0, step=0.1)

// MTF inputs
useMTF          = input.bool(true,      "Enable MTF Confirmation")
mtfTF           = input.timeframe("D", "Higher Timeframe")
mtfTrendLen     = input.int(50, "MTF EMA Length", minval=5)

// Visual inputs
showBands       = input.bool(true,  "Show Volatility Bands")
showSignals     = input.bool(true,  "Show Entry/Exit Signals")
showDashboard   = input.bool(true,  "Show Info Dashboard")
showMomentum    = input.bool(true,  "Show Momentum Histogram")

fillTransparency = input.int(75,    "Band Fill Transparency", minval=0, maxval=99)

// Color inputs
colTrendUp      = input.color(#26A69A, "Bullish Color")
colTrendDn      = input.color(#EF5350, "Bearish Color")
colNeutral      = input.color(#787B86, "Neutral Color")
colBandBase     = input.color(#2962FF, "Band Base Color")

// ─── Calculations ──────────────────────────────────────────────────────
// Trend: Exponential Moving Averages
fastEma  = ta.ema(trendSrc, trendFastLen)
slowEma  = ta.ema(trendSrc, trendSlowLen)
emaTrend = fastEma > slowEma ? 1 : -1

// Trend: ALMA (Arnaud Legoux Moving Average)
almaVal  = ta.alma(trendSrc, trendAlmaLen, almaOffset, almaSigma)
almaTrend = trendSrc > almaVal ? 1 : -1

// Trend: Supertrend
[stDir, stLine] = ta.supertrend(stFactor, stPeriod)
stTrend = stDir == 1 ? 1 : -1

// Composite Trend Score (range: -3 to +3)
trendScore = emaTrend + almaTrend + stTrend
trendBull  = trendScore > 0
trendBear  = trendScore < 0

// Adaptive RSI lookback based on volatility regime
atrVal     = ta.atr(atrLen)
baseAtr    = ta.sma(atrVal, 100)
volRatio   = atrVal / math.max(baseAtr, 0.0001)
adjRsiLen  = useAdaptive ? math.round(rsiLen * (1 + (volRatio - 1) * 0.5)) : rsiLen
adjRsiLen := math.max(math.min(adjRsiLen, 55), 3)

rsiVal     = ta.rsi(close, int(adjRsiLen))
rsiNorm    = (rsiVal - 50) * 2  // Normalized: roughly -100 to +100
rsiMomentum = ta.sma(rsiVal - 50, 3)

// Volatility Bands
bandCenter = ta.sma(close, atrLen)
bandUpper  = bandCenter + (atrVal * bandMultiplier)
bandLower  = bandCenter - (atrVal * bandMultiplier)
bandWidth  = ((bandUpper - bandLower) / bandCenter) * 100

// Volatility regime
volHigh    = bandWidth > ta.sma(bandWidth, 50) * 1.2
volLow     = bandWidth < ta.sma(bandWidth, 50) * 0.8

// MTF Trend Confirmation
// (function form recommended for request.security to avoid repaint)
mtfClose       = request.security(syminfo.tickerid, mtfTF, close, barmerge.gaps_off, lookahead=barmerge.lookahead_off)
mtfEma         = request.security(syminfo.tickerid, mtfTF, ta.ema(close, mtfTrendLen), barmerge.gaps_off, lookahead=barmerge.lookahead_off)
mtfTrendBull   = mtfClose > mtfEma
mtfTrendBear   = mtfClose < mtfEma
mtfConfirmed   = useMTF ? (trendBull ? mtfTrendBull : trendBear ? mtfTrendBear : true) : true

// ─── Signal Logic ──────────────────────────────────────────────────────
// Entry: strong trend + momentum alignment + MTF confirmation
longSignal  = (trendBull and rsiVal > 50 and rsiMomentum > 0 and mtfConfirmed) and (ta.crossover(fastEma, slowEma) or (ta.crossunder(rsiVal, rsiOS) and trendBull))

shortSignal = (trendBear and rsiVal < 50 and rsiMomentum < 0 and mtfConfirmed) and (ta.crossunder(fastEma, slowEma) or (ta.crossover(rsiVal, rsiOB) and trendBear))

// Exit: momentum exhaustion confirmed by MTF
longExit  = ta.crossunder(rsiVal, 50) and mtfConfirmed
shortExit = ta.crossover(rsiVal, 50) and mtfConfirmed

// ─── Plot: Aesthetic Price Colouring ───────────────────────────────────
// Color bars based on composite trend + momentum
barColor = trendBull ? (rsiVal > 60 ? colTrendUp : color.new(colTrendUp, 30)) : trendBear ? (rsiVal < 40 ? colTrendDn : color.new(colTrendDn, 30)) : colNeutral
barcolor(barColor)

// ─── Plot: Volatility Bands ────────────────────────────────────────────
pUpper = plot(showBands ? bandUpper : na, "Upper Band", color.new(colBandBase, 40), 1, plot.style_line, editable=false)
pMid   = plot(showBands ? bandCenter : na, "Mid Band", color.new(colBandBase, 20), 1, plot.style_dotted, editable=false)
pLower = plot(showBands ? bandLower : na, "Lower Band", color.new(colBandBase, 40), 1, plot.style_line, editable=false)

bandFillColor = volHigh ? color.new(color.orange, fillTransparency) : volLow ? color.new(color.olive, fillTransparency) : color.new(colBandBase, fillTransparency)
fill(pUpper, pLower, color=bandFillColor, editable=false, title="Band Fill")

// ─── Plot: Trend ALMA ──────────────────────────────────────────────────
plot(almaVal, "ALMA", color.new(#FFD54F, 40), 2, editable=false)

// ─── Plot: Supertrend Line ─────────────────────────────────────────────
plot(stLine, "Supertrend", stDir == 1 ? color.new(colTrendUp, 50) : color.new(colTrendDn, 50), 2, 
     plot.style_line, editable=false)

// ─── Plot: Signals ─────────────────────────────────────────────────────
plotshape(showSignals and longSignal ? low : na, "Long Entry", 
          shape.labelup, location.abovebar, colTrendUp, size=size.tiny, editable=false)
plotshape(showSignals and shortSignal ? high : na, "Short Entry", 
          shape.labeldown, location.belowbar, colTrendDn, size=size.tiny, editable=false)

plotshape(showSignals and longExit ? low : na, "Long Exit",
          shape.xcross, location.belowbar, color.new(colTrendDn, 70), size=size.tiny, editable=false)
plotshape(showSignals and shortExit ? high : na, "Short Exit",
          shape.xcross, location.abovebar, color.new(colTrendUp, 70), size=size.tiny, editable=false)

// ─── Momentum Histogram (in overlay pane, subtle) ──────────────────────
plot(showMomentum ? rsiNorm * 0.15 : na, "Momentum Bar", 
     rsiNorm > 0 ? color.new(colTrendUp, 60) : color.new(colTrendDn, 60), 
     2, plot.style_histogram, editable=false)

// ─── Dashboard Table ───────────────────────────────────────────────────
if (showDashboard)
    var infoTable = table.new(position.top_right, 2, 6,
                              bgcolor = color.new(#1E1E1E, 70),
                              border_width = 1,
                              border_color = color.new(#505050, 80),
                              frame_width = 0)

    // Header
    table.cell(infoTable, 0, 0, "NEXUS",
               text_color = color.white, text_halign = text.align_center,
               bgcolor = trendBull ? color.new(colTrendUp, 60) : 
                         trendBear ? color.new(colTrendDn, 60) : color.new(colNeutral, 60))

    table.cell(infoTable, 1, 0, "FLOW",
               text_color = color.white, text_halign = text.align_center,
               bgcolor = trendBull ? color.new(colTrendUp, 60) : 
                         trendBear ? color.new(colTrendDn, 60) : color.new(colNeutral, 60))

    // Trend row
    trendLabel = trendBull ? "▲ BULL" : trendBear ? "▼ BEAR" : "● SIDE"
    trendColor = trendBull ? colTrendUp : trendBear ? colTrendDn : colNeutral
    table.cell(infoTable, 0, 1, "Trend",  text_color = color.gray)
    table.cell(infoTable, 1, 1, trendLabel, text_color = trendColor)

    // Score row
    table.cell(infoTable, 0, 2, "Score",  text_color = color.gray)
    scoreStr = str.tostring(trendScore)
    scoreCol = trendScore > 0 ? colTrendUp : trendScore < 0 ? colTrendDn : colNeutral
    table.cell(infoTable, 1, 2, scoreStr, text_color = scoreCol)

    // RSI row
    table.cell(infoTable, 0, 3, "RSI",  text_color = color.gray)
    rsiStr = str.tostring(math.round(rsiVal, 1))
    rsiCol = rsiVal > rsiOB ? colTrendDn : rsiVal < rsiOS ? colTrendUp : colNeutral
    table.cell(infoTable, 1, 3, rsiStr, text_color = rsiCol)

    // Volatility row
    table.cell(infoTable, 0, 4, "Vol",  text_color = color.gray)
    volStr = str.tostring(math.round(bandWidth, 1))
    volCol = volHigh ? color.orange : volLow ? color.olive : colNeutral
    table.cell(infoTable, 1, 4, volStr + "%", text_color = volCol)

    // MTF row
    table.cell(infoTable, 0, 5, mtfTF,  text_color = color.gray)
    mtfLabel = mtfTrendBull ? "▲ BULL" : mtfTrendBear ? "▼ BEAR" : "—"
    mtfCol   = mtfTrendBull ? colTrendUp : mtfTrendBear ? colTrendDn : colNeutral
    table.cell(infoTable, 1, 5, mtfLabel, text_color = mtfCol)

// ─── Alert Conditions ──────────────────────────────────────────────────
alertcondition(longSignal,  "Nexus Long Entry",  "Nexus Flow: ▲ Long signal on {{ticker}} ({{exchange}})")
alertcondition(shortSignal, "Nexus Short Entry", "Nexus Flow: ▼ Short signal on {{ticker}} ({{exchange}})")
alertcondition(longExit,    "Nexus Long Exit",   "Nexus Flow: ✕ Long exit on {{ticker}} ({{exchange}})")
alertcondition(shortExit,   "Nexus Short Exit",  "Nexus Flow: ✕ Short exit on {{ticker}} ({{exchange}})")

// ─── Bar Coloring Guide (in description) ───────────────────────────────
// ─────────────────────────────────────────────────────────────────────────
//  How to read Nexus Flow:
//  ──────────────────────────────────────────────────────────────────────
//  Bar Colors    │ Solid Green  → Strong uptrend + momentum
//                │ Solid Red    → Strong downtrend + momentum
//                │ Pale colors  → Weak trend direction
//  ──────────────────────────────────────────────────────────────────────
//  Info Table    │ Trend  → Consensus direction (▲/▼/●)
//   (top-right)  │ Score  → Composite score (-3 to +3)
//                │ RSI    → Adaptive RSI value
//                │ Vol    → Bandwidth % (orange=high, olive=low)
//                │ [TF]   → Higher timeframe trend filter
//  ──────────────────────────────────────────────────────────────────────
//  Signals       │ Green "Long"  → Entry (trend + momentum + MTF aligned)
//                │ Red "Short"   → Entry (trend + momentum + MTF aligned)
//                │ Red ✕         → Exit long
//                │ Green ✕       → Exit short
//  ──────────────────────────────────────────────────────────────────────
//  Alerts        │ Configure via TradingView's alert dialog
//                │ Select "Nexus Long Entry" / "Nexus Short Entry" etc.
// ─────────────────────────────────────────────────────────────────────────
